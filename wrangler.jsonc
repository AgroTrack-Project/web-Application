{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agro-track",
  "compatibility_date": "2026-05-16",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist\\web-Application\\browser",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}